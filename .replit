modules = ["python-3.10", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Sync from GitHub"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m pytest tests/test_imports.py -v"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Sync from GitHub"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/sync_from_github.sh"

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "vm"
run = ["python", "-m", "pytest", "tests/test_imports.py", "-v"]
